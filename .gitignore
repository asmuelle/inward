# macOS
.DS_Store

# Xcode project is generated by XcodeGen (`just bootstrap`) — never commit it
*.xcodeproj/
*.xcworkspace/

# Build artifacts
DerivedData/
build/
*.ipa
*.dSYM
*.dSYM.zip
*.xcresult

# Swift Package Manager
.build/
.swiftpm/

# Xcode user state
xcuserdata/

# Secrets (defense in depth — the shipped app must not need any)
.env
.env.*

# Claude Code local overrides
.claude/settings.local.json
