    "NSFaceIDUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Inward kan bruge Face ID, så kun du kan åbne din dagbog." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Inward kann Face ID verwenden, damit nur du dein Journal öffnen kannst." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Inward puede usar Face ID para que solo tú puedas abrir tu diario." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Inward peut utiliser Face ID pour que toi seul puisses ouvrir ton journal." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Inward può usare Face ID così solo tu puoi aprire il tuo diario." } },
        "nb" : { "stringUnit" : { "state" : "translated", "value" : "Inward kan bruke Face ID slik at bare du kan åpne dagboken din." } },
        "pt" : { "stringUnit" : { "state" : "translated", "value" : "O Inward pode usar o Face ID para que só tu possas abrir o teu diário." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Inward может использовать Face ID, чтобы только ты мог открыть свой дневник." } },
