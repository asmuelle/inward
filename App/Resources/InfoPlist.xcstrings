    "NSMicrophoneUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Inward lytter kun, mens du optager. Lyden transskriberes på denne telefon og forlader den aldrig." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Inward hört nur zu, während du aufnimmst. Audio wird auf diesem Telefon transkribiert und verlässt es nie." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Inward solo escucha mientras grabas. El audio se transcribe en este teléfono y nunca sale de él." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Inward n’écoute que pendant que tu enregistres. L’audio est transcrit sur ce téléphone et ne le quitte jamais." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Inward ascolta solo mentre registri. L’audio viene trascritto su questo telefono e non lo lascia mai." } },
        "nb" : { "stringUnit" : { "state" : "translated", "value" : "Inward lytter bare mens du tar opp. Lyden transkriberes på denne telefonen og forlater den aldri." } },
        "pt" : { "stringUnit" : { "state" : "translated", "value" : "O Inward só ouve enquanto gravas. O áudio é transcrito neste telefone e nunca o deixa." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Inward слушает только во время записи. Аудио расшифровывается на этом телефоне и никогда его не покидает." } },
        "sv" : { "stringUnit" : { "state" : "translated", "value" : "Inward lyssnar bara medan du spelar in. Ljudet transkriberas på den här telefonen och lämnar den aldrig." } }
      }
    },
